{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mail Widgets",
  "version": "0.1.0",
  "identifier": "com.zoroofcoding.mailwidgets",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Daily Gmail Widget",
        "width": 360,
        "height": 520,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "category": "Productivity",
    "shortDescription": "Desktop Gmail widget for unread email updates.",
    "longDescription": "Mail Widgets is a lightweight desktop Gmail widget that stays on the desktop layer and shows recent unread messages with periodic refresh.",
    "publisher": "zoro-of-coding",
    "copyright": "Copyright (c) zoro-of-coding",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
