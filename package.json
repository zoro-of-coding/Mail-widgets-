{
  "name": "mail-widgets",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "build": "electron-builder",
    "build:windows": "electron-builder --win nsis msi",
    "build:linux": "electron-builder --linux appimage deb",
    "build:macos": "electron-builder --mac dmg"
  },
  "devDependencies": {
    "electron": "^32.2.0",
    "electron-builder": "^24.13.3"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "build": {
    "appId": "com.zoroofcoding.mailwidgets",
    "productName": "Mail Widgets",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "config",
        "to": "config",
        "filter": [
          "google_oauth.json",
          "google_oauth.example.json"
        ]
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "msi"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    }
  }
}
